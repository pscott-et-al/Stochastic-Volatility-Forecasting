# =============================================================================
# CELL 3 | Step 2 — SDE Specification (Ornstein-Uhlenbeck)
# =============================================================================
#
# Latent volatility modeled as OU process:
#   dσ_t = κ(θ − σ_t) dt + ξ dW_t
#
# Closed-form solution via Itô's Lemma:
#   σ_t = θ + (σ_0 − θ)e^{−κt} + ξ ∫_0^t e^{−κ(t−s)} dW_s
#
# Conditional moments (parameterize Kalman transition):
#   E[σ_t | σ_0]   = θ + (σ_0 − θ) e^{−κt}
#   Var[σ_t | σ_0] = (ξ²/2κ)(1 − e^{−2κt})
#
# These moments map directly to the state-space parameters in Step 3.
# =============================================================================

def ou_to_ss(kappa, theta, xi, dt=1/252):
    """
    Convert OU parameters (kappa, theta, xi) to discrete-time
    state-space parameters (alpha, beta, Q) via the Ito's lemma
    conditional moments. Derivation in paper Section 4.3.

    Parameters
    ----------
    kappa : float  — mean reversion speed
    theta : float  — long-run mean volatility
    xi    : float  — volatility of volatility
    dt    : float  — time step in years (1/252 for daily)

    Returns
    -------
    alpha : float  — state-space intercept
    beta  : float  — state-space AR coefficient
    Q     : float  — process noise variance
    """
    beta  = np.exp(-kappa * dt)
    alpha = theta * (1 - beta)
    Q     = (xi**2 / (2 * kappa)) * (1 - np.exp(-2 * kappa * dt))
    return alpha, beta, Q

