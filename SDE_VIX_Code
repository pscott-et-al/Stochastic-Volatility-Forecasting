# =============================================================================
# CELL 4 | Step 3 — State-Space Construction
# =============================================================================
#
# Transition:   σ_{t+1} = α + β σ_t + w_t,  w_t ~ N(0, Q)
# Observation:  y_t     = σ_t + v_t,         v_t ~ N(0, R)
#
# α, β, Q are exact functions of (κ, θ, ξ) via Itô's lemma (Cell 3).
# R is the measurement noise variance — estimated in Step 4.
# =============================================================================

def build_kalman_matrices(kappa, theta, xi, R, dt=1/252):
    """
    Construct state-space matrices from OU parameters.
    Convention:
        x_{t+1} = F x_t + b + w_t     (transition)
        y_t     = H x_t + v_t         (observation)

    Returns
    -------
    Dictionary of Kalman matrices (alpha, beta, Q, R, initial state)
    """
    alpha, beta, Q = ou_to_ss(kappa, theta, xi, dt)

    return {
        'transition_matrices':     np.array([[beta]]),
        'transition_offsets':      np.array([alpha]),
        'observation_matrices':    np.array([[1.0]]),
        'observation_offsets':     np.array([0.0]),
        'transition_covariance':   np.array([[Q]]),
        'observation_covariance':  np.array([[R]]),
        'initial_state_mean':      np.array([theta]),
        'initial_state_covariance':np.array([[xi**2 / (2 * kappa)]]),
    }

print("State-space construction function defined.")
print("Observation equation: y_t = σ_t + v_t, v_t ~ N(0, R)")
print("Transition equation:  σ_{t+1} = α + β σ_t + w_t, w_t ~ N(0, Q)")


# =============================================================================
# CELL 5 | Step 4A — Parameter Estimation via EM Algorithm (numpy only)
# =============================================================================
#
# Primary method: EM algorithm (Expectation-Maximization)
#   E-step: Kalman smoother — forward filter + backward (RTS) smoother pass
#   M-step: update (alpha, beta, Q, R) to maximize expected log-likelihood
#
# Implemented from scratch in numpy — no pykalman dependency.
# =============================================================================

def kalman_smoother_em(y, alpha, beta, Q, R, theta, xi, kappa, dt=1/252):
    """
    Kalman forward filter + RTS backward smoother.
    Returns smoothed means, smoothed variances, and cross-covariances
    needed for the EM M-step.
    """
    T = len(y)

    # --- Forward filter ---
    sigma_f  = np.zeros(T)     # filtered means
    P_f      = np.zeros(T)     # filtered variances
    sigma_p  = np.zeros(T)     # predicted means
    P_p      = np.zeros(T)     # predicted variances

    sigma_prev = theta
    P_prev     = xi**2 / (2 * kappa)

    for t in range(T):
        sigma_p[t] = alpha + beta * sigma_prev
        P_p[t]     = beta**2 * P_prev + Q

        S          = P_p[t] + R
        K          = P_p[t] / S
        sigma_f[t] = sigma_p[t] + K * (y[t] - sigma_p[t])
        P_f[t]     = (1 - K) * P_p[t]

        sigma_prev = sigma_f[t]
        P_prev     = P_f[t]

    # --- RTS backward smoother ---
    sigma_s = np.zeros(T)     # smoothed means
    P_s     = np.zeros(T)     # smoothed variances
    P_cross = np.zeros(T)     # cross-covariance E[x_t x_{t-1} | Y]

    sigma_s[-1] = sigma_f[-1]
    P_s[-1]     = P_f[-1]

    for t in range(T-2, -1, -1):
        G           = P_f[t] * beta / P_p[t+1]
        sigma_s[t]  = sigma_f[t] + G * (sigma_s[t+1] - sigma_p[t+1])
        P_s[t]      = P_f[t]  + G**2 * (P_s[t+1] - P_p[t+1])
        P_cross[t+1]= G * P_s[t+1]

    return sigma_s, P_s, P_cross, sigma_f, P_f


def run_em(y, n_iter=80, dt=1/252):
    """
    Full EM loop for OU state-space model.
    Initializes from sample moments and iterates E/M steps.
    Returns estimated OU parameters (kappa, theta, xi, R).
    """
    T = len(y)

    # --- Initialization from sample moments ---
    theta = float(np.mean(y))
    xi    = float(np.std(y)) * 0.5
    kappa = 5.0                        # ~50-day half-life starting point
    R     = float(np.var(y)) * 0.1

    alpha, beta, Q = ou_to_ss(kappa, theta, xi, dt)

    prev_ll = -np.inf

    for iteration in range(n_iter):
        # --- E-step: Kalman smoother ---
        sigma_s, P_s, P_cross, sigma_f, P_f = kalman_smoother_em(
            y, alpha, beta, Q, R, theta, xi, kappa, dt
        )

        # Sufficient statistics for M-step
        # E[x_t^2]
        Ex2      = P_s + sigma_s**2
        # E[x_t x_{t-1}]
        Ext_xt1  = P_cross[1:] + sigma_s[1:] * sigma_s[:-1]

        # --- M-step: update parameters ---
        # Update beta (AR coefficient) and alpha (intercept)
        # From MLE of transition: sigma_{t+1} = alpha + beta*sigma_t + w_t
        S_xx  = Ex2[:-1].sum()
        S_yx  = Ext_xt1.sum()
        S_yy  = Ex2[1:].sum()
        S_x   = sigma_s[:-1].sum()
        S_y   = sigma_s[1:].sum()
        n     = T - 1

        denom = n * S_xx - S_x**2
        beta  = (n * S_yx - S_x * S_y) / denom
        alpha = (S_y - beta * S_x) / n

        # Update Q (process noise)
        Q = (S_yy - beta * S_yx - alpha * S_y
             - beta * S_yx + beta**2 * S_xx + alpha * beta * S_x
             - alpha * S_y + alpha * beta * S_x + alpha**2 * n) / n
        Q = max(Q, 1e-10)   # numerical floor

        # Update R (measurement noise)
        # Floor at 5% of sample variance — rolling RV is noisy by construction
        # (21-day overlapping windows), so R collapsing to zero is not valid
        R_min = float(np.var(y)) * 0.05
        R = float(np.mean((y - sigma_s)**2 + P_s))
        R = max(R, R_min)

        # Back out OU parameters
        beta  = np.clip(beta, 1e-6, 1 - 1e-6)
        kappa = -np.log(beta) / dt
        theta_new = alpha / (1 - beta)
        xi_new    = np.sqrt(max(Q * 2 * kappa / (1 - np.exp(-2 * kappa * dt)), 1e-10))

        theta = theta_new
        xi    = xi_new
        alpha, beta_new, Q = ou_to_ss(kappa, theta, xi, dt)
        beta = beta_new

        # Monitor log-likelihood for convergence
        ll = -0.5 * np.sum((y - sigma_f)**2 / (P_f + R) + np.log(P_f + R))
        if abs(ll - prev_ll) < 1e-6 and iteration > 5:
            print(f"  EM converged at iteration {iteration+1}  |  LL = {ll:.4f}")
            break
        prev_ll = ll

    return kappa, theta, xi, R


print("Running EM parameter estimation (numpy, no external dependencies)...")
print("(Typically converges in 20-60 iterations)")

