# =============================================================================
# CELL 7 | Step 5 — Kalman Filter Recursion
# =============================================================================
#
# Predict:   σ̂_{t|t-1} = α + β σ̂_{t-1|t-1}
#            P_{t|t-1}  = β² P_{t-1|t-1} + Q
#
# Update:    K_t        = P_{t|t-1} / (P_{t|t-1} + R)
#            σ̂_{t|t}   = σ̂_{t|t-1} + K_t · ν_t
#            P_{t|t}    = (1 - K_t) · P_{t|t-1}
#
# Diagnostic: Ljung-Box test on innovations ν_t for whiteness.
# =============================================================================

def run_kalman_filter(y, kappa, theta, xi, R, dt=1/252):
    """
    Forward Kalman filter recursion for the OU state-space model.
    Returns filtered state estimates, posterior variances, and innovations.

    Parameters
    ----------
    y     : array-like  — observation series (noisy realized vol)
    kappa : float       — mean reversion speed
    theta : float       — long-run mean
    xi    : float       — vol of vol
    R     : float       — measurement noise variance
    dt    : float       — time step in years

    Returns
    -------
    sigma_hat : np.array  — filtered state estimates σ̂_{t|t}
    P_t       : np.array  — posterior variances P_{t|t}
    nu_t      : np.array  — innovations ν_t = y_t − σ̂_{t|t-1}
    K_t       : np.array  — Kalman gains
    """
    alpha, beta, Q = ou_to_ss(kappa, theta, xi, dt)
    T = len(y)

    sigma_hat = np.zeros(T)
    P_t       = np.zeros(T)
    nu_t      = np.zeros(T)
    K_t       = np.zeros(T)

    # Initialize at stationary distribution
    sigma_hat_prev = theta
    P_prev         = xi**2 / (2 * kappa)

    for t in range(T):
        # --- Prediction step ---
        sigma_pred = alpha + beta * sigma_hat_prev
        P_pred     = beta**2 * P_prev + Q

        # --- Innovation ---
        nu_t[t] = y[t] - sigma_pred

        # --- Kalman gain ---
        K_t[t] = P_pred / (P_pred + R)

        # --- Update step ---
        sigma_hat[t] = sigma_pred + K_t[t] * nu_t[t]
        P_t[t]       = (1 - K_t[t]) * P_pred

        # Carry forward
        sigma_hat_prev = sigma_hat[t]
        P_prev         = P_t[t]

    return sigma_hat, P_t, nu_t, K_t


