from scipy.stats import ttest_ind

# -------------------------------------------------------------------------
# 10A: Gaussian Kernel Smoother — Static Baseline (Section 6.4)
# -------------------------------------------------------------------------

def gaussian_kernel_smooth(y, bandwidth=63):
    """
    Nadaraya-Watson kernel smoother with Gaussian kernel.
    Produces a static smoothed estimate of the vol series.
    Bandwidth h controls smoothness (in trading days, default ~1 quarter).
    """
    T = len(y)
    y_smooth = np.zeros(T)
    t_idx = np.arange(T, dtype=float)
    for t in range(T):
        weights = np.exp(-0.5 * ((t_idx - t) / bandwidth) ** 2)
        y_smooth[t] = np.sum(weights * y) / np.sum(weights)
    return y_smooth

print("Computing Gaussian kernel smoother (bandwidth = 63 days) ...")
