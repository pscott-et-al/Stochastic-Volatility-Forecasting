# =============================================================================
# CELL 6 | Step 4B — Parameter Estimation via MLE (scipy cross-check)
# =============================================================================
#
# Cross-check using prediction error decomposition:
#   log L = -T/2 log(2π) - 1/2 Σ_t [log(P_{t|t-1} + R) + ν_t²/(P_{t|t-1} + R)]
#
# Maximize over (κ, θ, ξ, R).
# =============================================================================

def kalman_nll(params, y, dt=1/252):
    """
    Negative log-likelihood via prediction error decomposition.
    Used for MLE cross-check against EM estimates.
    """
    kappa, theta, xi, R = params

    # Parameter constraints — return large penalty if violated
    if kappa <= 0 or xi <= 0 or R <= 0 or theta <= 0:
        return 1e10

    alpha, beta, Q = ou_to_ss(kappa, theta, xi, dt)
    T = len(y)

    # Initialize filter
    sigma_hat = theta
    P = xi**2 / (2 * kappa)
    nll = 0.0

    for t in range(T):
        # Prediction step
        sigma_pred = alpha + beta * sigma_hat
        P_pred     = beta**2 * P + Q

        # Innovation
        S   = P_pred + R           # innovation variance
        nu  = y[t] - sigma_pred    # innovation

        # Log-likelihood contribution
        nll += 0.5 * (np.log(2 * np.pi * S) + nu**2 / S)

        # Update step
        K         = P_pred / S
        sigma_hat = sigma_pred + K * nu
        P         = (1 - K) * P_pred

    return nll

# Initial guess from EM estimates — warm start
